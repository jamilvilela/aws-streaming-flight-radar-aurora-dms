AWS_REGION="us-east-1"
environment="production"

# ─────────────────────────────────────────────────────────────────────────────
# Aurora PostgreSQL — Senha do admin
# O setup-env.sh exporta para TF_VAR_rds_admin_password automaticamente
# ─────────────────────────────────────────────────────────────────────────────
RDS_ADMIN_USERNAME="<user_name>"
RDS_ADMIN_PASSWORD="<sua_senha_segura_aqui>"

# ─────────────────────────────────────────────────────────────────────────────
# Aurora PostgreSQL — Configuração de conexão
# Preencha com os valores exibidos pelo setup-env.sh ao final do deploy
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST="<aurora_endpoint>"
DB_PORT="5432"
DB_NAME="flightradar"
DB_USER="dbadmin"
DB_PASSWORD="<sua_senha>"
