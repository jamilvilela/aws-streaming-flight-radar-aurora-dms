AWS_REGION="us-east-1"
environment="production"

# ─────────────────────────────────────────────────────────────────────────────
# Aurora PostgreSQL — Credenciais de admin
# O setup-env.sh exporta como TF_VAR_rds_admin_username / TF_VAR_rds_admin_password
# ─────────────────────────────────────────────────────────────────────────────
DB_USER="<user_name>"
DB_PASSWORD="<sua_senha_segura_aqui>"

# ─────────────────────────────────────────────────────────────────────────────
# Aurora PostgreSQL — Configuração de conexão (opcional pós-deploy)
# Preencha com os valores exibidos pelo setup-env.sh ao final do deploy
# ─────────────────────────────────────────────────────────────────────────────
# DB_HOST="<aurora_endpoint>"
# DB_PORT="5432"
# DB_NAME="flightradar"
